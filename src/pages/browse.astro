---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.tsx';
import { getModelList } from '../lib/models';

const models = await getModelList();
const base = import.meta.env.BASE_URL;
const basePrefix = base.endsWith('/') ? base : base + '/';

const modelsWithBase = models.map(m => ({
  ...m,
  url: `${basePrefix}${m.url.replace(/^\//, '')}`,
  json: `${basePrefix}${m.json.replace(/^\//, '')}`,
}));
---

<BaseLayout title="Browse | vLLM-Ascend Recipes">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <h1 class="font-display text-2xl font-bold text-ink-50 tracking-tight" data-i18n="browseTitle">Browse all recipes</h1>
        <span class="font-mono text-xs text-ink-600">[ {models.length} total ]</span>
      </div>
      <p class="text-sm text-ink-500" data-i18n="browseDescription">
        Filter by NPU type, architecture, modality, or search by model name.
      </p>
    </div>

    <SearchBar client:load models={modelsWithBase} />
  </section>
</BaseLayout>
